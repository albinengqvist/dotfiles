[user]
  name = Albin Engqvist
  email = albinengqvist@gmail.com  # byt till din GitHub-email

[core]
	editor = hx
  autocrlf = input

[color]
  ui = auto

[alias]
  co = checkout
  br = branch
  ci = commit
  st = status
  lg = log --oneline --graph --all --decorate

[pull]
  rebase = true

[push]
  default = current

[init]
  defaultBranch = main

[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
